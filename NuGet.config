<?xml version="1.0" encoding="utf-8"?>
<!--
  Keep the feeds list explicit and minimal. No private/Azure DevOps feeds
  so restore works for anyone cloning this repo without auth.
-->
<configuration>
  <packageSources>
    <clear/>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3"/>
  </packageSources>
  <disabledPackageSources>
    <clear/>
  </disabledPackageSources>
</configuration>
