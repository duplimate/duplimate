<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="using:Duplimate.Views"
             x:Class="Duplimate.App"
             RequestedThemeVariant="Light">

  <Application.DataTemplates>
    <v:ViewLocator/>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme/>
    <StyleInclude Source="avares://Duplimate/Themes/Controls.axaml"/>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://Duplimate/Themes/Theme.axaml"/>
        <!-- Default accent merged statically so DynamicResource lookups for
             DM.Brush.Accent etc. resolve at template-parse time. Without
             this, any ControlTemplate authored with DynamicResource for an
             accent brush evaluates before code-behind has merged the user's
             chosen accent dict, caches a failed lookup in that template
             context, and never updates. Code-behind
             (App.ApplyAccentFromConfig) still swaps in the user's preferred
             accent on top of this default. -->
        <ResourceInclude Source="avares://Duplimate/Themes/Accent_Ocean.axaml"/>
        <ResourceInclude Source="avares://Duplimate/Themes/Icons.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
