<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Inline-SVG-path icons, sized to 24×24 viewBox. Reused across the
    sidebar, section headers, and row glyphs via the `SvgIcon` style.
    Paths are traced from Lucide (ISC license), simplified where useful.

    Usage:
      <PathIcon Data="{StaticResource Icon.Dashboard}"/>
  -->

  <!-- Dashboard — layout-dashboard -->
  <StreamGeometry x:Key="Icon.Dashboard">M3 3h7v9H3zM14 3h7v5h-7zM14 12h7v9h-7zM3 16h7v5H3z</StreamGeometry>

  <!-- Backup — archive (stacked snapshots) -->
  <StreamGeometry x:Key="Icon.Backup">M3 8V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v3M3 8h18M3 8v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8M10 12h4</StreamGeometry>

  <!-- Destinations — hard-drive / cloud abstract -->
  <StreamGeometry x:Key="Icon.Destinations">M22 12H2M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11zM6 16h.01M10 16h.01</StreamGeometry>

  <!-- Activity — list / pulse -->
  <StreamGeometry x:Key="Icon.Activity">M22 12h-4l-3 9L9 3l-3 9H2</StreamGeometry>

  <!-- Restore — clock with arrow back / rotate-ccw -->
  <StreamGeometry x:Key="Icon.Restore">M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8M3 3v5h5M12 7v5l4 2</StreamGeometry>

  <!-- Settings — gear -->
  <StreamGeometry x:Key="Icon.Settings">M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z</StreamGeometry>

  <!-- Plus — for "Add" buttons -->
  <StreamGeometry x:Key="Icon.Plus">M12 5v14M5 12h14</StreamGeometry>

  <!-- ChevronRight — "navigates forward" affordance on click-to-jump
       cards. Lucide chevron-right, simplified. -->
  <StreamGeometry x:Key="Icon.ChevronRight">M9 6l6 6-6 6</StreamGeometry>

  <!-- Edit — pencil -->
  <StreamGeometry x:Key="Icon.Edit">M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z</StreamGeometry>

  <!-- Trash — for delete -->
  <StreamGeometry x:Key="Icon.Trash">M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2M10 11v6M14 11v6</StreamGeometry>

  <!-- Compress — for Prune (compact storage by deleting older
       revisions). Lucide `minimize-2`: four diagonal arrows pointing
       toward the centre. Universally read as "shrink / make smaller"
       which is exactly what Prune does to the storage footprint.
       The earlier scissors glyph was too abstract at 12px. -->
  <StreamGeometry x:Key="Icon.Compress">M4 14h6v6M20 10h-6V4M14 10l7-7M3 21l7-7</StreamGeometry>

  <!-- Eraser — for Erase (wipe ALL data this backup has stored at
       a destination). Lucide `eraser`: a literal eraser rubbing-out
       a line. Reads as "wipe clean" at any size — clearer than the
       flame glyph it replaced, which only read as fire at large
       sizes. -->
  <StreamGeometry x:Key="Icon.Eraser">M7 21l-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21M22 21H7M5 11l9 9</StreamGeometry>

  <!-- Folder — local -->
  <StreamGeometry x:Key="Icon.Folder">M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z</StreamGeometry>

  <!-- HardDrive — external -->
  <StreamGeometry x:Key="Icon.HardDrive">M22 12H2M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11zM6 16h.01M10 16h.01</StreamGeometry>

  <!-- Cloud — generic cloud -->
  <StreamGeometry x:Key="Icon.Cloud">M17.5 19a4.5 4.5 0 1 0 0-9 5.5 5.5 0 0 0-10.83-1.27A4 4 0 0 0 6.5 19z</StreamGeometry>

  <!-- Network — network / server -->
  <StreamGeometry x:Key="Icon.Network">M5 12V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v7M2 15a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2zM6 18h.01</StreamGeometry>

  <!-- Database — S3-compatible -->
  <StreamGeometry x:Key="Icon.Database">M12 8a9 3 0 1 0 0-6 9 3 0 0 0 0 6zM3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5M3 12c0 1.66 4 3 9 3s9-1.34 9-3</StreamGeometry>

  <!-- ================================================================= -->
  <!-- Status glyphs — paired with accent / warn / danger foregrounds     -->
  <!-- ================================================================= -->

  <!-- Check — run succeeded.

       Path is drawn around (12,12) by construction so the glyph sits
       centred inside the surrounding status-badge disc without any
       Margin compensation. The Lucide original (`M5 13l4 4L19 7`)
       is bbox-centred at (12,12) but its V-vertex at (9,17) sits
       visibly below disc centre — the eye reads "low and left".
       This redraw places the V-vertex at (10,15), shortens the long
       arm, and keeps both arms within an 11-px-tall band centred
       vertically, so the visual mass aligns with the disc centre. -->
  <StreamGeometry x:Key="Icon.Check">M6 12l4 3l8 -7</StreamGeometry>

  <!-- Alert triangle — warning -->
  <StreamGeometry x:Key="Icon.Warn">M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01</StreamGeometry>

  <!-- X circle — failure -->
  <StreamGeometry x:Key="Icon.Fail">M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM15 9l-6 6M9 9l6 6</StreamGeometry>

  <!-- Skipped — "skip-forward" track glyph (audio-player convention).
       Earlier this was a "pause" pair which read as "you can resume
       this" — but a stopped backup can't be resumed, so the audio-app
       skip-track triangle + bar reads more accurately as "we moved
       past this run". -->
  <StreamGeometry x:Key="Icon.Skipped">M5 4 L15 12 L5 20 Z M19 5 L19 19</StreamGeometry>

  <!-- Running — loader with two missing arc segments. Renders as a
       circle with two gaps so the eye reads "in motion / spinner" even
       though the path itself is static (status-icon position is paired
       with a separate animated ProgressBar elsewhere on the card). -->
  <StreamGeometry x:Key="Icon.Running">M21 12a9 9 0 1 1-6.219-8.56M21 3v6h-6</StreamGeometry>

  <!-- Idle / never run — empty circle outline. Distinct from a status
       dot so the user reads "not started yet" rather than "neutral". -->
  <StreamGeometry x:Key="Icon.Idle">M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z</StreamGeometry>

  <!-- ================================================================= -->
  <!-- Action glyphs                                                       -->
  <!-- ================================================================= -->

  <!-- Play — Run now -->
  <StreamGeometry x:Key="Icon.Play">M5 3l14 9-14 9z</StreamGeometry>

  <!-- X / close — clear-selection buttons, dismiss affordances -->
  <StreamGeometry x:Key="Icon.X">M18 6L6 18M6 6l12 12</StreamGeometry>

  <!-- Clipboard — Paste affordance next to the OAuth token field. -->
  <StreamGeometry x:Key="Icon.Clipboard">M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2M9 2h6a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1z</StreamGeometry>

  <!-- GitHub mark — official Octocat outline as a single closed path,
       designed to be filled (not stroked). The path is the real
       GitHub favicon mark — disc with the cat silhouette cut out
       through fill-rule=evenodd. Renders as a filled black/dark disc
       at any size, matching how GitHub itself ships the favicon. -->
  <StreamGeometry x:Key="Icon.GitHub">F1 M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z</StreamGeometry>

  <!-- Copy — Logs view "Copy to clipboard" button. Two overlapping
       rounded squares = standard "duplicate / copy" iconography. -->
  <StreamGeometry x:Key="Icon.Copy">M8 4h11a2 2 0 0 1 2 2v11M3 8h11a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2z</StreamGeometry>

  <!-- Folder open — Open log folder, Browse -->
  <StreamGeometry x:Key="Icon.FolderOpen">M6 14l1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H18a2 2 0 0 1 2 2v2</StreamGeometry>

  <!-- ================================================================= -->
  <!-- Large illustrative glyphs for empty-state cards                     -->
  <!-- (same paths, rendered at larger size + accent tint background)      -->
  <!-- ================================================================= -->

  <!-- Sparkle / welcome -->
  <StreamGeometry x:Key="Icon.Sparkle">M12 3l2.5 6.5L21 12l-6.5 2.5L12 21l-2.5-6.5L3 12l6.5-2.5z</StreamGeometry>

  <!-- Paint palette — Settings/Appearance -->
  <StreamGeometry x:Key="Icon.Palette">M12 2a10 10 0 1 0 10 10c0-1.5-1-3-2.5-3H17a3 3 0 0 1-3-3v-1.5A3.5 3.5 0 0 0 10.5 1zM7 11h.01M10 7h.01M13 7h.01M16 9h.01</StreamGeometry>

  <!-- Bell — notifications -->
  <StreamGeometry x:Key="Icon.Bell">M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9M10.3 21a1.94 1.94 0 0 0 3.4 0</StreamGeometry>

  <!-- Heart pulse — healthchecks -->
  <StreamGeometry x:Key="Icon.HeartPulse">M19 14c1.49-1.46 3-3.21 3-5.5a5.5 5.5 0 0 0-10-3.15A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7zM3.22 12H9.5l.5-1 2 4 .5-2 1 1h5.27</StreamGeometry>

  <!-- Mail — email alerts -->
  <StreamGeometry x:Key="Icon.Mail">M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm18 2l-10 7L2 6</StreamGeometry>

  <!-- File text — logs & diagnostics -->
  <StreamGeometry x:Key="Icon.FileText">M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8</StreamGeometry>

  <!-- Clock — restore/time -->
  <StreamGeometry x:Key="Icon.Clock">M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM12 6v6l4 2</StreamGeometry>

  <!-- Arrow right — wizard next -->
  <StreamGeometry x:Key="Icon.ArrowRight">M5 12h14M12 5l7 7-7 7</StreamGeometry>

  <!-- ========== Brand icons (stroked outlines under our global stroke-2 -->
  <!-- PathIcon template — recognizable silhouettes without brand colour).  -->

  <!-- Dropbox: four rhombi forming the stacked-box mark. 24x24 viewbox. -->
  <StreamGeometry x:Key="Icon.BrandDropbox">M7 3l5 3-5 3-5-3zM17 3l5 3-5 3-5-3zM7 9l5 3-5 3-5-3zM17 9l5 3-5 3-5-3zM7 17l5-3 5 3-5 3z</StreamGeometry>

  <!-- OneDrive: distinctive four-lobe cloud silhouette. -->
  <StreamGeometry x:Key="Icon.BrandOneDrive">M6 18a4 4 0 0 1 .4-7.97A5 5 0 0 1 11 6a5 5 0 0 1 4.8 3.6A4 4 0 0 1 22 13a4 4 0 0 1-4 4H6z</StreamGeometry>

  <!-- Google Drive: three-triangle folded sheet mark. -->
  <StreamGeometry x:Key="Icon.BrandGoogleDrive">M8 3h8l6 11-4 7H6L2 14zM8 3L2 14M16 3l6 11M10 14h12M6 21l4-7M18 21l-4-7</StreamGeometry>

</ResourceDictionary>
