<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
    Duplimate — default theme.
    Calm-editorial structure: clean white canvas, sidebar on a subtle
    warm tint, hairline borders, no drop shadows. Distinctive accents
    (not generic SaaS blue) and deliberate typography.
  -->

  <ResourceDictionary.ThemeDictionaries>

    <!-- =============== LIGHT (default) =============== -->
    <!--
      Warm-paper palette tuned for WCAG AA on the cream surface. Previous
      values (#5F5F5F / #989898) were cool-toned and FgDim failed AA at
      2.83:1. New values are warm grays that pass AA against both #FFFFFF
      and #F9F7F3 surfaces and read calm at arm's length on a 27" display.
    -->
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="DM.Brush.BgBase"           Color="#FFFFFFFF"/>
      <SolidColorBrush x:Key="DM.Brush.BgSurface"        Color="#FFFBF8F2"/>
      <SolidColorBrush x:Key="DM.Brush.BgElevated"       Color="#FFFFFFFF"/>
      <SolidColorBrush x:Key="DM.Brush.FgPrimary"        Color="#FF1A1915"/> <!-- inky warm black -->
      <SolidColorBrush x:Key="DM.Brush.FgSecondary"      Color="#FF4A4740"/> <!-- AA 8.9:1 on cream -->
      <SolidColorBrush x:Key="DM.Brush.FgDim"            Color="#FF6A665C"/> <!-- AA 4.67:1 on cream -->
      <!-- Tonal palette anchored to Tailwind scale values, which is a
           well-tested neutral standard for tonal buttons / callouts in
           both light and dark themes:
             • solid Danger / Success / Warn   = -700  (foreground + outline)
             • light-mode Tint                  = -100  (resting bg)
             • light-mode TintHover             = -200  (hover bg)
             • dark-mode Tint                   = -900  (see Dark dictionary)
             • dark-mode TintHover              = -800  (see Dark dictionary)
           Aligning to a published scale avoids the "is it filled or
           translucent?" perception bug the previous bespoke values
           had — at -100/-900 the button has a clear coloured-fill
           identity in either mode without shouting. -->
      <SolidColorBrush x:Key="DM.Brush.Warn"             Color="#FFB45309"/> <!-- amber-700 -->
      <SolidColorBrush x:Key="DM.Brush.WarnTint"         Color="#FFFEF3C7"/> <!-- amber-100 -->
      <SolidColorBrush x:Key="DM.Brush.Danger"           Color="#FFB91C1C"/> <!-- red-700 -->
      <SolidColorBrush x:Key="DM.Brush.DangerTint"       Color="#FFFEE2E2"/> <!-- red-100 -->
      <SolidColorBrush x:Key="DM.Brush.Success"          Color="#FF15803D"/> <!-- green-700 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessTint"      Color="#FFDCFCE7"/> <!-- green-100 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessTintHover" Color="#FFBBF7D0"/> <!-- green-200 -->
      <SolidColorBrush x:Key="DM.Brush.DangerTintHover"  Color="#FFFECACA"/> <!-- red-200 -->
      <SolidColorBrush x:Key="DM.Brush.WarnTintHover"    Color="#FFFDE68A"/> <!-- amber-200 -->
      <!-- "On-tint" foregrounds — the colour used for TEXT (and any
           icon stroked at text weight) placed ON a Tint background.
           In light mode this is the same -700 used elsewhere
           (sufficient contrast on -100 bg). The split is necessary
           in dark mode (see Dark dictionary), so for symmetry the
           brushes exist in both themes. -->
      <SolidColorBrush x:Key="DM.Brush.SuccessTintFg"    Color="#FF15803D"/> <!-- green-700 -->
      <SolidColorBrush x:Key="DM.Brush.DangerTintFg"     Color="#FFB91C1C"/> <!-- red-700 -->
      <SolidColorBrush x:Key="DM.Brush.WarnTintFg"       Color="#FFB45309"/> <!-- amber-700 -->
      <!-- "Solid hover" — the darker tonal shade used when an
           outlined-at-rest button fills solid on hover (Primer-style
           danger button). Tailwind -800 in light mode goes darker on
           hover, the convention used by Bootstrap / shadcn / Primer. -->
      <SolidColorBrush x:Key="DM.Brush.SuccessHover"     Color="#FF166534"/> <!-- green-800 -->
      <SolidColorBrush x:Key="DM.Brush.DangerHover"      Color="#FF991B1B"/> <!-- red-800 -->
      <SolidColorBrush x:Key="DM.Brush.WarnHover"        Color="#FF92400E"/> <!-- amber-800 -->
      <!-- Mantine v7 "light" variant — light theme. Recipe:
             bg=shade-1, hover=shade-2, fg=shade-9. Palette is Open
             Color v8. Values verified against Mantine's resolver
             source (mantine/core/src/core/MantineProvider/
              MantineCssVariables/get-css-color-variables.ts) +
             snapshot tests. Used by the row-level action buttons
             (Restore files / Delete / Erase / Remove / Prune / Stop /
             Proceed). -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightBg"      Color="#FFFFE3E3"/> <!-- red.1 -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightBgHover" Color="#FFFFC9C9"/> <!-- red.2 -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightFg"      Color="#FFC92A2A"/> <!-- red.9 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightBg"     Color="#FFD3F9D8"/> <!-- green.1 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightBgHover" Color="#FFB2F2BB"/> <!-- green.2 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightFg"     Color="#FF2B8A3E"/> <!-- green.9 -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightBg"        Color="#FFFFE8CC"/> <!-- orange.1 -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightBgHover"   Color="#FFFFD8A8"/> <!-- orange.2 -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightFg"        Color="#FFD9480F"/> <!-- orange.9 -->
      <!-- Mantine v7 "filled" variant for critical/destructive
           actions one tier above row-action-danger ("Erase ALL data"
           vs the gentler "Remove this destination"). Default
           primaryShade = 6 in light. Hover darkens by one step. -->
      <SolidColorBrush x:Key="DM.Brush.DangerFilledBg"     Color="#FFFA5252"/> <!-- red.6 -->
      <SolidColorBrush x:Key="DM.Brush.DangerFilledBgHover" Color="#FFF03E3E"/> <!-- red.7 -->
      <!-- Faint outline for the light-variant buttons. User asked:
           "same colour as the inner text" — so hue matches LightFg
           (shade-9). Alpha 0x40 (~25%) keeps a SOFT visual line — at
           full alpha a 1px stroke of shade-9 reads as a heavy band
           against the pale shade-1 fill; ~25% alpha is the same hue
           but visually a hair-thin line. Dark mode keeps it
           transparent (the dark-tint bg pops enough on its own). -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightBorder"  Color="#40C92A2A"/> <!-- red.9 @ ~25% alpha -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightBorder" Color="#402B8A3E"/> <!-- green.9 @ ~25% -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightBorder"    Color="#40D9480F"/> <!-- orange.9 @ ~25% -->
      <SolidColorBrush x:Key="DM.Brush.BorderSubtle"     Color="#FFE0DCD2"/> <!-- hairline, just visible -->
      <SolidColorBrush x:Key="DM.Brush.BorderEmphasized" Color="#FFB9B4A7"/> <!-- input border, 1.85:1 on white -->
      <!-- Neutral hover background — used by ghost / outlined buttons
           and any control that wants a calm "cursor is over me" cue
           without invoking the accent colour. ~3% black over the cream
           surface; visible but doesn't compete with the accent. -->
      <SolidColorBrush x:Key="DM.Brush.NeutralHover"     Color="#FFF1ECE0"/>
      <SolidColorBrush x:Key="DM.Brush.NeutralPressed"   Color="#FFE6E0D2"/>
      <!-- Card band tint — used by the BackupCard's tinted header /
           footer bands. ~2.5% darker than BgSurface (#FBF8F2). The
           prior #F1ECE0 was too yellow ("brownish") and #F7F4ED was
           too close to BgSurface (the band separators read as
           "missing borders"); this value sits between them — visible
           band/body contrast, less yellow tilt than NeutralHover. -->
      <SolidColorBrush x:Key="DM.Brush.CardBandTint"     Color="#FFF3EFE6"/>
      <!-- Accent brushes (Accent / AccentHover / AccentDeep / AccentTint) come
           from a separate Accent_*.axaml merged at runtime by App.axaml.cs. -->
    </ResourceDictionary>

    <!-- =============== DARK =============== -->
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="DM.Brush.BgBase"           Color="#FF141414"/>
      <SolidColorBrush x:Key="DM.Brush.BgSurface"        Color="#FF1C1C1C"/>
      <SolidColorBrush x:Key="DM.Brush.BgElevated"       Color="#FF242424"/>
      <SolidColorBrush x:Key="DM.Brush.FgPrimary"        Color="#FFF2F1EE"/>
      <SolidColorBrush x:Key="DM.Brush.FgSecondary"      Color="#FFBFBBB2"/> <!-- lifted for warmth -->
      <SolidColorBrush x:Key="DM.Brush.FgDim"            Color="#FF8F8B82"/> <!-- AA 5.8:1 on BgSurface -->
      <!-- Dark-mode tonal palette — Tailwind -500 solids paired with
           -950 resting Tints and -900 hover Tints. The previous
           -900/-800 pairing produced the "vibrant filled tonal
           button" Tailwind/Material standard, but the user asked for
           a "very faint" feel — so dropped one step on the scale.
           -950 resting + -900 hover matches roughly where Bootstrap
           5.3's dark-mode alert backgrounds sit
           (`#051B11`/`#2C0B0E`/`#332701`) — clearly tinted but quiet,
           with the bg far enough from BgSurface to read as "filled"
           rather than alpha-translucent. -->
      <SolidColorBrush x:Key="DM.Brush.Warn"             Color="#FFEAB308"/> <!-- yellow-500 -->
      <SolidColorBrush x:Key="DM.Brush.WarnTint"         Color="#FF422006"/> <!-- yellow-950 -->
      <SolidColorBrush x:Key="DM.Brush.Danger"           Color="#FFEF4444"/> <!-- red-500 -->
      <SolidColorBrush x:Key="DM.Brush.DangerTint"       Color="#FF450A0A"/> <!-- red-950 -->
      <SolidColorBrush x:Key="DM.Brush.Success"          Color="#FF22C55E"/> <!-- green-500 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessTint"      Color="#FF052E16"/> <!-- green-950 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessTintHover" Color="#FF14532D"/> <!-- green-900 -->
      <SolidColorBrush x:Key="DM.Brush.DangerTintHover"  Color="#FF7F1D1D"/> <!-- red-900 -->
      <SolidColorBrush x:Key="DM.Brush.WarnTintHover"    Color="#FF713F12"/> <!-- yellow-900 -->
      <!-- "On-tint" foregrounds — the colour used for TEXT placed ON
           the dark Tint background. The standard Tailwind / Material 3
           pattern for dark-mode tonal buttons is `bg=-900, text=-300`
           (NOT `text=-500`). -500 is the saturated colour reserved
           for icons / dots on the surface; on a -900 / -950 button
           background it FAILS WCAG contrast badly. -300 is the
           tonal-light shade meant exactly for this role — ~5:1
           contrast on -900, ~9:1 on -950. -->
      <SolidColorBrush x:Key="DM.Brush.SuccessTintFg"    Color="#FF86EFAC"/> <!-- green-300 -->
      <SolidColorBrush x:Key="DM.Brush.DangerTintFg"     Color="#FFFCA5A5"/> <!-- red-300 -->
      <SolidColorBrush x:Key="DM.Brush.WarnTintFg"       Color="#FFFDE047"/> <!-- yellow-300 -->
      <!-- Solid hover — dark mode goes LIGHTER on hover (Tailwind
           -400) per Primer's dark-mode convention (the button "lifts
           forward" rather than "presses in"). -->
      <SolidColorBrush x:Key="DM.Brush.SuccessHover"     Color="#FF4ADE80"/> <!-- green-400 -->
      <SolidColorBrush x:Key="DM.Brush.DangerHover"      Color="#FFF87171"/> <!-- red-400 -->
      <SolidColorBrush x:Key="DM.Brush.WarnHover"        Color="#FFFACC15"/> <!-- yellow-400 -->
      <!-- Mantine v7 "light" variant — dark theme. Recipe:
             bg=darken(shade-9, 0.5), hover=darken(shade-9, 0.3),
             fg=shade-0. Palette is Open Color v8. Values verified
             against Mantine's resolver source
             (mantine/core/src/core/MantineProvider/MantineCssVariables/
              get-css-color-variables.ts) + snapshot tests. -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightBg"      Color="#FF651515"/> <!-- darken(red.9, 0.5) -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightBgHover" Color="#FF8D1D1D"/> <!-- darken(red.9, 0.3) -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightFg"      Color="#FFFFF5F5"/> <!-- red.0 -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightBg"     Color="#FF16451F"/> <!-- darken(green.9, 0.5) -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightBgHover" Color="#FF1E612B"/> <!-- darken(green.9, 0.3) -->
      <SolidColorBrush x:Key="DM.Brush.SuccessLightFg"     Color="#FFEBFBEE"/> <!-- green.0 -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightBg"        Color="#FF6D2408"/> <!-- darken(orange.9, 0.5) -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightBgHover"   Color="#FF98320B"/> <!-- darken(orange.9, 0.3) -->
      <SolidColorBrush x:Key="DM.Brush.WarnLightFg"        Color="#FFFFF4E6"/> <!-- orange.0 -->
      <!-- Mantine v7 "filled" variant — dark theme uses primaryShade
           = 8. See light-theme comment for rationale. -->
      <SolidColorBrush x:Key="DM.Brush.DangerFilledBg"     Color="#FFE03131"/> <!-- red.8 -->
      <SolidColorBrush x:Key="DM.Brush.DangerFilledBgHover" Color="#FFF03E3E"/> <!-- red.7 (lifts toward cursor in dark) -->
      <!-- Dark mode: no outline (the dark tint stands out enough
           against the charcoal surface on its own). Transparent so
           the button style can set BorderThickness=1 unconditionally
           without painting anything in dark mode. -->
      <SolidColorBrush x:Key="DM.Brush.DangerLightBorder"  Color="#00000000"/>
      <SolidColorBrush x:Key="DM.Brush.SuccessLightBorder" Color="#00000000"/>
      <SolidColorBrush x:Key="DM.Brush.WarnLightBorder"    Color="#00000000"/>
      <SolidColorBrush x:Key="DM.Brush.BorderSubtle"     Color="#FF33312D"/>
      <SolidColorBrush x:Key="DM.Brush.BorderEmphasized" Color="#FF4E4B45"/>
      <!-- Neutral hover lightens the dark surface ~6% — ghost buttons
           and outlined controls signal "you're hovering me" by
           coming forward, mirroring the light-theme darken pattern. -->
      <SolidColorBrush x:Key="DM.Brush.NeutralHover"     Color="#FF2A2A2A"/>
      <SolidColorBrush x:Key="DM.Brush.NeutralPressed"   Color="#FF353535"/>
      <!-- Dark-mode card-band tint — slightly elevated above BgSurface
           so the header / footer bands feel like a distinct layer. -->
      <SolidColorBrush x:Key="DM.Brush.CardBandTint"     Color="#FF232323"/>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <FontFamily x:Key="DM.Font.Display">Segoe UI Variable Display, Segoe UI Variable, Segoe UI, system-ui, sans-serif</FontFamily>
  <FontFamily x:Key="DM.Font.Body">Segoe UI Variable Text, Segoe UI Variable, Segoe UI, system-ui, sans-serif</FontFamily>
  <FontFamily x:Key="DM.Font.Mono">Cascadia Mono, Consolas, monospace</FontFamily>

  <CornerRadius x:Key="DM.CornerRadius">10</CornerRadius>
  <CornerRadius x:Key="DM.CornerRadiusSmall">8</CornerRadius>
  <CornerRadius x:Key="DM.CornerRadiusButton">8</CornerRadius>

  <!--
    FluentTheme's TimePicker template uses a static resource key
    `TimePickerHostPadding` (Thickness) on each segment TextBlock's
    Padding. Default is asymmetric ("0,3,0,6"-ish) which makes the
    digits hang low against neighbouring 40px-tall inputs. Our
    earlier `TimePicker /template/ TextBlock#PART_*` Style overrides
    can't beat a template-local Padding=StaticResource binding —
    StaticResource values resolve at template-parse time and aren't
    affected by downstream Style setters.

    Re-defining the resource key here in App resources changes what
    the template binds against, so every TimePicker in the app picks
    up zero padding and the digits sit dead-centre.
  -->
  <Thickness x:Key="TimePickerHostPadding">0</Thickness>
  <Thickness x:Key="TimePickerHostBorderThickness">0</Thickness>

</ResourceDictionary>
