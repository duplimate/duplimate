<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Duplimate.ViewModels"
        x:Class="Duplimate.Views.ChangeStoragePasswordWindow"
        Title="Change storage password — Duplimate"
        Width="560" SizeToContent="Height"
        CanResize="False"
        Background="{DynamicResource DM.Brush.BgBase}"
        WindowStartupLocation="CenterOwner">

  <StackPanel Margin="34,30,34,26" Spacing="18">
    <StackPanel Spacing="6">
      <TextBlock x:Name="TitleBlock" Classes="card-title"/>
      <TextBlock Classes="body" TextWrapping="Wrap"
                 Foreground="{DynamicResource DM.Brush.FgSecondary}"
                 Text="Duplicacy re-encrypts the small config file that holds the storage's master key. The chunks themselves stay untouched (they're encrypted with the master key, which doesn't change), so this finishes in seconds and works on storages of any size."/>
    </StackPanel>

    <Border Classes="rule"/>

    <StackPanel Spacing="6">
      <TextBlock Classes="label-caps" Text="NEW STORAGE PASSWORD"/>
      <TextBox x:Name="NewPasswordBox"
               PasswordChar="•"
               Watermark="At least 8 characters"/>
      <TextBlock Classes="helper"
                 Text="Store it somewhere safe (e.g. your password manager). If you lose it the backup data on this destination becomes unreadable, even though you'll still have the backups locally."/>
    </StackPanel>
    <StackPanel Spacing="6">
      <TextBlock Classes="label-caps" Text="CONFIRM NEW PASSWORD"/>
      <TextBox x:Name="ConfirmPasswordBox" PasswordChar="•"/>
    </StackPanel>

    <!-- Status / error feedback. The validation-summary border is the
         red error banner; the StatusInfo text is for in-progress
         "Connecting…" / "Re-encrypting…" / "Done — secret updated"
         messages. -->
    <Border Classes="validation-summary" x:Name="ErrorBanner" IsVisible="False">
      <Grid ColumnDefinitions="Auto,10,*">
        <TextBlock Grid.Column="0" Text="!" FontSize="18" FontWeight="Bold" VerticalAlignment="Top"
                   Foreground="{DynamicResource DM.Brush.DangerTintFg}"/>
        <TextBlock Grid.Column="2" x:Name="ErrorText"
                   Classes="body" FontWeight="SemiBold" TextWrapping="Wrap"
                   Foreground="{DynamicResource DM.Brush.DangerTintFg}"/>
      </Grid>
    </Border>

    <!-- Status row: spinner + text. The spinner stays in the visual
         tree but only animates while busy (via IsLiveAttached-style
         IsIndeterminate gating). Without this, the dialog froze with
         all buttons greyed out and no motion for 5-30s of remote
         re-encrypt — users assumed the app crashed. -->
    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center"
                x:Name="StatusRow" IsVisible="False">
      <ProgressBar x:Name="StatusSpinner"
                   IsIndeterminate="True"
                   Width="80" Height="4"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource DM.Brush.Accent}"
                   Background="{DynamicResource DM.Brush.AccentTint}"/>
      <TextBlock x:Name="StatusInfo" Classes="dim" FontSize="13"
                 VerticalAlignment="Center"/>
    </StackPanel>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Classes="ghost" Content="Cancel" Click="OnCancel" x:Name="CancelButton"/>
      <Button Classes="primary" Content="Change password" Click="OnConfirm" x:Name="ConfirmButton"/>
    </StackPanel>
  </StackPanel>
</Window>
