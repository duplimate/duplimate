<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Duplimate.Views.GeneratedPasswordWindow"
        Title="Save this password — Duplimate"
        Width="560" SizeToContent="Height"
        CanResize="False"
        Background="{DynamicResource DM.Brush.BgBase}"
        WindowStartupLocation="CenterOwner">

  <!--
    Shown once after a destination Save when the user opted into
    encryption AND left the storage-password field blank, asking us to
    auto-generate one. The plaintext is on the clipboard automatically
    on open; we also render the password in a read-only mono TextBox
    so the user can verify what they're saving + manually copy if their
    clipboard manager strips it. Closing the window without saving the
    password is the user's choice — we made the affordance explicit.
  -->

  <StackPanel Margin="32,28,32,24" Spacing="18">
    <StackPanel Spacing="8">
      <TextBlock Classes="card-title" Text="Save this password somewhere safe"/>
      <TextBlock Classes="body" TextWrapping="Wrap"
                 Text="We generated this password so you didn't have to. It's been copied to your clipboard. Paste it into a password manager (or anywhere safe) before closing — we won't show it again."/>
      <TextBlock Classes="body" TextWrapping="Wrap"
                 Foreground="{DynamicResource DM.Brush.Danger}"
                 Text="If you lose this password, the encrypted backup data CANNOT be recovered."/>
    </StackPanel>

    <Grid ColumnDefinitions="*,8,Auto">
      <TextBox Grid.Column="0"
               x:Name="PasswordBox"
               IsReadOnly="True"
               FontFamily="{DynamicResource DM.Font.Mono}" FontSize="13"/>
      <Button Grid.Column="2" Classes="ghost" Click="OnCopy">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource Icon.Clipboard}" Width="13" Height="13"/>
          <TextBlock Text="Copy" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Classes="primary" Content="I've saved it" Click="OnDone"/>
    </StackPanel>
  </StackPanel>
</Window>
